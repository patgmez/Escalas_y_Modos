        </thead>
        <tbody>
            <tr>
                <td><span class="scale-name-btn" onclick="playFromFormula('1, 2, 3, #4, #5, b7')">Tonos Enteros</span></td>
                <td>T - T - T - T - T - T</td>
                <td>1, 2, 3, #4, #5, b7</td>

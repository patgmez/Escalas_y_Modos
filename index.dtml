    <h2>7. Familia Octatónica (Bebop & Dim)</h2>
    <div class="table-container">
    <table>
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Estructura</th>
                <th>Fórmula</th>
                <th>Concepto Teórico</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><span class="scale-name-btn" onclick="playFromFormula('1, 2, b3, 4, b5, b6, 6, 7')">Disminuida T-S</span></td>
                <td>T - S - T - S - T - S - T - S</td>
                <td>1, 2, b3, 4, b5, b6, 6, 7</td>
                <td>Sobre acordes dim7</td>
            </tr>
            <tr>
                <td><span class="scale-name-btn" onclick="playFromFormula('1, b2, b3, 3, #4, 5, 6, b7')">Disminuida S-T</span></td>
                <td>S - T - S - T - S - T - S - T</td>
                <td>1, b2, b3, 3, #4, 5, 6, b7</td>
                <td>Sobre Dominantes (V7b9)</td>
            </tr>
            <tr>
                <td><span class="scale-name-btn" onclick="playFromFormula('1, 2, 3, 4, 5, #5, 6, 7')">Bebop Mayor</span></td>
                <td>T - T - S - T - S - S - T - S</td>
                <td>1, 2, 3, 4, 5, #5, 6, 7</td>
                <td>Jazz, énfasis rítmico</td>
            </tr>
            <tr>
                <td><span class="scale-name-btn" onclick="playFromFormula('1, 2, 3, 4, 5, 6, b7, 7')">Bebop Dominante</span></td>
                <td>T - T - S - T - T - S - S - S</td>
                <td>1, 2, 3, 4, 5, 6, b7, 7</td>
                <td>Mixolidia cromática</td>
            </tr>
        </tbody>
    </table>
    </div>

<script>
    // --- 1. CONFIGURACIÓN DE AUDIO ---
    const AudioContext = window.AudioContext || window.webkitAudioContext;
    let audioCtx;
    const BASE_FREQ_C4 = 261.63; 

    function initAudio() {
        if (!audioCtx) { audioCtx = new AudioContext(); }
        if (audioCtx.state === 'suspended') { audioCtx.resume(); }
    }

    function playTone(freq, startTime, duration) {
        const osc = audioCtx.createOscillator();
        const gainNode = audioCtx.createGain();
        const filter = audioCtx.createBiquadFilter();
        
        osc.type = 'sawtooth'; 
        osc.frequency.value = freq;
        filter.type = 'lowpass';
        filter.frequency.value = 600; 
        filter.Q.value = 1;

        gainNode.gain.setValueAtTime(0, startTime);
        gainNode.gain.linearRampToValueAtTime(0.3, startTime + 0.15); 
        gainNode.gain.setValueAtTime(0.3, startTime + duration - 0.05); 
        gainNode.gain.linearRampToValueAtTime(0.001, startTime + duration + 0.3); 
        
        osc.connect(filter);
        filter.connect(gainNode);
        gainNode.connect(audioCtx.destination);
        
        osc.start(startTime);
        osc.stop(startTime + duration + 0.3); 
    }

    function getFrequencyFromSemitones(semitonesFromC4) {
        return BASE_FREQ_C4 * Math.pow(2, semitonesFromC4 / 12);
    }

    let currentScaleNotes = [];

    // --- FUNCIÓN MODIFICADA: ASCENDENTE Y DESCENDENTE ---
    function playCurrentScale() {
        initAudio();
        const now = audioCtx.currentTime;
        let timeOffset = 0;
        
        // Ajustes de tiempos
        const noteDuration = 0.4; // Duración de sonido
        const noteGap = 0.4;      // Espacio entre notas
        const topPause = 0.4;     // Pausa extra arriba

        // 1. CALCULAR SECUENCIA ASCENDENTE (con corrección de octavas)
        let octaveShift = 0;
        let lastNoteVal = -1;
        let absoluteSequence = [];

        // Convertir notas relativas a semitonos absolutos incrementales
        currentScaleNotes.forEach((noteVal) => {
            if (noteVal < lastNoteVal) { octaveShift += 12; }
            absoluteSequence.push(noteVal + octaveShift);
            lastNoteVal = noteVal;
        });

        // Añadir la tónica en la octava superior para cerrar la escala
        const rootNote = currentScaleNotes[0];
        let finalHighNote = rootNote;
        // Aseguramos que la nota final sea más aguda que la última de la secuencia
        while (finalHighNote <= absoluteSequence[absoluteSequence.length - 1]) {
            finalHighNote += 12;
        }
        absoluteSequence.push(finalHighNote);

        // 2. REPRODUCIR SUBIDA
        absoluteSequence.forEach((semitone) => {
            const freq = getFrequencyFromSemitones(semitone);
            playTone(freq, now + timeOffset, noteDuration);
            timeOffset += noteGap;
        });

        // 3. PAUSA ARRIBA
        timeOffset += topPause;

        // 4. REPRODUCIR BAJADA
        // Invertimos la secuencia completa
        const descendingSequence = [...absoluteSequence].reverse();
        
        descendingSequence.forEach((semitone) => {
            const freq = getFrequencyFromSemitones(semitone);
            playTone(freq, now + timeOffset, noteDuration);
            timeOffset += noteGap;
        });
    }

    // --- 2. BASE DE DATOS CORREGIDA ---
    const scalesDatabase = [
        { name: "Pentatónica Mayor", formula: "1,2,3,5,6", category: "Pentatónicas", character: "Universal, mayor sin tensión" },
        { name: "Egyptia / Suspendida", formula: "1,2,4,5,b7", category: "Pentatónicas", character: "Suspendida, sin 3ª" },
        { name: "Man Gong", formula: "1,b3,4,b6,b7", category: "Pentatónicas", character: "Oscura" },
        { name: "Ritusen / Neutral", formula: "1,2,4,5,6", category: "Pentatónicas", character: "Luminosa" },
        { name: "Pentatónica Menor", formula: "1,b3,4,5,b7", category: "Pentatónicas", character: "Universal, menor" },
        
        { name: "Tonos Enteros", formula: "1,2,3,#4,#5,b7", category: "Exóticas", character: "Debussy, ambigua" },
        { name: "Escala Blues", formula: "1,b3,4,b5,5,b7", category: "Exóticas", character: "Penta menor + blue note" },
        { name: "Aumentada", formula: "1,b3,3,5,#5,7", category: "Exóticas", character: "Tríada aumentada base" },
        { name: "Prometeo", formula: "1,2,3,#4,6,b7", category: "Exóticas", character: "Scriabin, mística" },
        { name: "Hirajoshi", formula: "1,2,b3,5,b6", category: "Exóticas", character: "Japón, nostálgica" },
        { name: "Mayor Armónica", formula: "1,2,3,4,5,b6,7", category: "Exóticas", character: "Mayor con b6" },
        
        { name: "Jónico (Mayor)", formula: "1,2,3,4,5,6,7", category: "Heptatonía Primera", character: "Mayor, luminoso" },
        { name: "Dórico", formula: "1,2,b3,4,5,6,b7", category: "Heptatonía Primera", character: "Menor luminoso" },
        { name: "Frigio", formula: "1,b2,b3,4,5,b6,b7", category: "Heptatonía Primera", character: "Menor oscuro" },
        { name: "Lidio", formula: "1,2,3,#4,5,6,7", category: "Heptatonía Primera", character: "Mayor etéreo" },
        { name: "Mixolidio", formula: "1,2,3,4,5,6,b7", category: "Heptatonía Primera", character: "Dominante (V7)" },
        { name: "Eólico", formula: "1,2,b3,4,5,b6,b7", category: "Heptatonía Primera", character: "Menor natural" },
        { name: "Locrio", formula: "1,b2,b3,4,b5,b6,b7", category: "Heptatonía Primera", character: "Disminuido" },
        
        { name: "Menor Melódica (I)", formula: "1,2,b3,4,5,6,7", category: "Heptatonía Segunda", character: "Menor con 6 y 7 Mayor" },
        { name: "Dórica b2 (II)", formula: "1,b2,b3,4,5,6,b7", category: "Heptatonía Segunda", character: "Sonido Susb9" },
        { name: "Lidia Aumentada (III)", formula: "1,2,3,#4,#5,6,7", category: "Heptatonía Segunda", character: "Etéreo inestable" },
        { name: "Lidia Dominante (IV)", formula: "1,2,3,#4,5,6,b7", category: "Heptatonía Segunda", character: "Dominante acústico" },
        { name: "Mixolidia b6 (V)", formula: "1,2,3,4,5,b6,b7", category: "Heptatonía Segunda", character: "Melancolía mayor" },
        { name: "Locria #2 (VI)", formula: "1,2,b3,4,b5,b6,b7", category: "Heptatonía Segunda", character: "Semidisminuido estable" },
        { name: "Super Locria / Alterada (VII)", formula: "1,b2,#2,3,b5,b6,b7", category: "Heptatonía Segunda", character: "Dominante muy tenso" },

        { name: "Menor Armónica (I)", formula: "1,2,b3,4,5,b6,7", category: "Heptatonía Tercera", character: "Menor clásico" },
        { name: "Locria 6 (II)", formula: "1,b2,b3,4,b5,6,b7", category: "Heptatonía Tercera", character: "Semidisminuido brillante" },
        { name: "Jónica Aumentada (III)", formula: "1,2,3,4,#5,6,7", category: "Heptatonía Tercera", character: "Mayor aumentado" },
        { name: "Dórica #4 (IV)", formula: "1,2,b3,#4,5,6,b7", category: "Heptatonía Tercera", character: "Dórica con #4" },
        { name: "Frigia Dominante (V)", formula: "1,b2,3,4,5,b6,b7", category: "Heptatonía Tercera", character: "Español / Flamenco" },
        { name: "Lidia #2 (VI)", formula: "1,#2,3,#4,5,6,7", category: "Heptatonía Tercera", character: "Lidia exótica" },
        { name: "Ultralocria (VII)", formula: "1,b2,b3,3,b5,b6,bb7", category: "Heptatonía Tercera", character: "Disminuido total" },

        { name: "Doble Armónica", formula: "1,b2,3,4,5,b6,7", category: "Otras Exóticas", character: "Oriental, árabe" },
        { name: "Napolitana Menor", formula: "1,b2,b3,4,5,b6,7", category: "Otras Exóticas", character: "Oscura con sensible" },
        { name: "Napolitana Mayor", formula: "1,b2,3,4,5,6,7", category: "Otras Exóticas", character: "Mayor exótica (3M)" },
        { name: "Enigmática", formula: "1,b2,3,#4,#5,#6,7", category: "Otras Exóticas", character: "Verdi, atonal" },

        { name: "Disminuida T-S", formula: "1,2,b3,4,b5,b6,6,7", category: "Octatónicas", character: "Acordes disminuidos" },
        { name: "Disminuida S-T", formula: "1,b2,b3,3,#4,5,6,b7", category: "Octatónicas", character: "Dominante alterada" },
        { name: "Bebop Mayor", formula: "1,2,3,4,5,#5,6,7", category: "Octatónicas", character: "Jazz rítmico" },
        { name: "Bebop Dominante", formula: "1,2,3,4,5,6,b7,7", category: "Octatónicas", character: "Jazz dominante" }
    ];

    // --- 3. MAPEO Y UTILIDADES ---
    const noteMap = {
        'C': 0, 'Do': 0, 'C#': 1, 'Db': 1, 'Do#': 1, 'Reb': 1,
        'D': 2, 'Re': 2, 'D#': 3, 'Eb': 3, 'Re#': 3, 'Mib': 3,
        'E': 4, 'Mi': 4, 'F': 5, 'Fa': 5, 'F#': 6, 'Gb': 6, 'Fa#': 6, 'Solb': 6,
        'G': 7, 'Sol': 7, 'G#': 8, 'Ab': 8, 'Sol#': 8, 'Lab': 8,
        'A': 9, 'La': 9, 'A#': 10, 'Bb': 10, 'La#': 10, 'Sib': 10,
        'B': 11, 'Si': 11
    };
    const numberToNote = ['C', 'C#/Db', 'D', 'D#/Eb', 'E', 'F', 'F#/Gb', 'G', 'G#/Ab', 'A', 'A#/Bb', 'B'];

    function getIntervalName(semitones) {
        if (semitones === 1) return "S";
        if (semitones === 2) return "T";
        if (semitones === 3) return "1½T";
        if (semitones === 4) return "2T";
        return semitones + "st";
    }

    function notesToIntervalSteps(noteValues) {
        const steps = [];
        for (let i = 0; i < noteValues.length - 1; i++) {
            let diff = (noteValues[i+1] - noteValues[i] + 12) % 12;
            if (diff === 0) diff = 12; 
            steps.push(diff);
        }
        let lastStep = (noteValues[0] - noteValues[noteValues.length - 1] + 12) % 12;
        if (lastStep === 0) lastStep = 12; 
        steps.push(lastStep);
        return steps;
    }

    function getAbsoluteSemitonesFromFormula(formula) {
        const intervals = {
            '1': 0, 'b2': 1, '2': 2, '#2': 3,
            'b3': 3, '3': 4, 
            '4': 5, '#4': 6, 'b5': 6, 
            '5': 7, '#5': 8, 'b6': 8, 
            '6': 9, '#6': 10, 'bb7': 9,
            'b7': 10, '7': 11
        };
        
        const absolutePositions = formula.split(',')
            .map(i => intervals[i.trim()])
            .filter(v => v !== undefined)
            .sort((a, b) => a - b);
            
        return [...new Set(absolutePositions)];
    }

    function formulaToIntervalSteps(formula) {
        const uniquePositions = getAbsoluteSemitonesFromFormula(formula);
        return notesToIntervalSteps(uniquePositions);
    }

    function parseNotes(input) {
        const notesStr = input.trim().replace(/,/g, ' ').replace(/\s+/g, ' ');
        const noteNames = notesStr.split(' ').filter(n => n.length > 0);
        
        const chromaticValues = [];
        for (let noteName of noteNames) {
            let formattedName = noteName.charAt(0).toUpperCase() + noteName.slice(1).toLowerCase();
            if (noteMap.hasOwnProperty(formattedName)) {
                chromaticValues.push(noteMap[formattedName]);
            } else { return null; }
        }
        return [...new Set(chromaticValues)]; 
    }

    function arraysMatch(arr1, arr2) {
        if (arr1.length !== arr2.length) return false;
        for (let i = 0; i < arr1.length; i++) {
            if (arr1[i] !== arr2[i]) return false;
        }
        return true;
    }

    // --- LÓGICA UI ---
    function playFromFormula(formula) {
        const semitones = getAbsoluteSemitonesFromFormula(formula);
        currentScaleNotes = semitones;
        playCurrentScale();
    }

    function detectScale() {
        const input = document.getElementById('notesInput').value;
        const resultsDiv = document.getElementById('results');
        const resultsContent = document.getElementById('resultsContent');
        
        const userNotes = parseNotes(input);
        
        if (!userNotes || userNotes.length < 3) { 
            resultsContent.innerHTML = '<div class="no-results">⚠️ Introduce al menos 3 notas válidas.</div>';
            resultsDiv.classList.add('show');
            return;
        }

        currentScaleNotes = userNotes;
        const userStructure = notesToIntervalSteps(userNotes);
        const structureString = userStructure.map(s => getIntervalName(s)).join(' - ');
        
        const foundMatches = [];
        
        for (let scale of scalesDatabase) {
            const dbStructure = formulaToIntervalSteps(scale.formula);
            if (arraysMatch(userStructure, dbStructure)) {
                foundMatches.push(scale);
            }
        }

        let html = '';
        
        if (foundMatches.length === 0) {
            html += `
                <div class="no-results">
                    <p>❌ <strong>Escala no encontrada en la base de datos.</strong></p>
                    <p>Estructura: <strong>${structureString}</strong></p>
                    <div style="margin-top:15px;">
                         <button class="detect-btn" style="background-color:#3498db; width:auto; padding: 10px 20px;" onclick="playCurrentScale()">🔊 Escuchar esta estructura</button>
                    </div>
                </div>`;
        } else {
            html += `<div style="background:#e8f5e9; padding:15px; border-radius:5px; margin-bottom:15px; border-left: 5px solid #4CAF50; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
                        <div><strong>Estructura detectada:</strong> ${structureString}</div>
                        <button class="detect-btn" style="background-color:#3498db; width:auto; margin:0; padding: 8px 16px; font-size:14px;" onclick="playCurrentScale()">🔊 Escuchar Escala</button>
                     </div>`;
            
            html += `<p><strong>✅ Se identificó la siguiente escala:</strong></p>`;
            
            for (let match of foundMatches) {
                const tonicName = numberToNote[userNotes[0]]; 
                html += `
                    <div class="result-item">
                        <strong>${match.name}</strong> (Tónica: ${tonicName})
                        <p><strong>Categoría:</strong> ${match.category}</p>
                        <p><strong>Fórmula:</strong> ${match.formula}</p>
                        <p><strong>Carácter:</strong> ${match.character}</p>
                    </div>
                `;
            }
        }
        
        resultsContent.innerHTML = html;
        resultsDiv.classList.add('show');
    }

    document.getElementById('notesInput').addEventListener('keypress', function(event) {
        if (event.key === 'Enter') detectScale();
    });
</script>

</body>
</html>
